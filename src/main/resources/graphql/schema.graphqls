scalar Date @specifiedBy(url:"https://tools.ietf.org/html/rfc3339")

type Query{
    findAllCats: [Cat!]!
}

type Mutation{
    addNewCat(catInput: CatInput): Cat
    updateCat(catId: ID!, catInput: CatInput): Cat
}

type Cat{
    id: ID!
    name: String
    birthday: Date
    gender: Gender
    human: [Human]
}

type Human{
    id: ID!
    firstName: String
    lastName: String
    phone: String
    email: String
}
input CatInput{
    name: String
    birthday: Date
    gender: Gender
}
